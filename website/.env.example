# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Public
NEXT_PUBLIC_BASE_URL=https://gatetest.ai
NEXT_PUBLIC_APP_VERSION=1.0.0

# Gluecron (primary git host)
GLUECRON_BASE_URL=https://gluecron.com
GLUECRON_API_TOKEN=glc_...
GLUECRON_API_URL=https://gluecron.com/api
GLUECRON_TOKEN=glc_...

# GitHub App (dual-host — GitHub Marketplace distribution)
GATETEST_APP_ID=
GATETEST_PRIVATE_KEY=
GATETEST_WEBHOOK_SECRET=
GATETEST_GITHUB_TOKEN=
GIT_HOST=github

# GitHub OAuth (admin panel + customer login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=
SESSION_SECRET=

# Admin
GATETEST_ADMIN_PASSWORD=change_me_before_deploy
GATETEST_ADMIN_USERNAMES=
GATETEST_API_KEY=
# Internal machine-to-machine token for fix registry (falls back to GATETEST_ADMIN_PASSWORD)
GATETEST_INTERNAL_TOKEN=
# Vercel Cron auth — set to any random secret; Vercel sends it as "Authorization: Bearer <value>"
# Without this, /api/watches/tick and /api/scan/worker/tick are open to any caller in production
CRON_SECRET=

# AI
ANTHROPIC_API_KEY=

# Database (Neon serverless Postgres)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Build metadata (set by CI — no value needed locally)
APP_VERSION=
GIT_COMMIT=

# SSH healing (optional — remote server access for auto-fix)
GATETEST_SSH_HOST=
GATETEST_SSH_PORT=22
GATETEST_SSH_USER=
GATETEST_SSH_PASSWORD=
GATETEST_SSH_KEY=

# Runtime / monitoring (optional — CLI and monitor daemon)
GATETEST_ADMIN_URL=https://gatetest.ai/admin
GATETEST_ALERT_WEBHOOK=
GATETEST_REPORTS_DIR=.gatetest/reports
GATETEST_PURGE_WEBHOOK=
GATETEST_DEPLOY_HOOK=
GATETEST_RESTART_HOOK=
GATETEST_FIX_MAX_ATTEMPTS=3
GATETEST_CALLBACK_SECRET=
GATETEST_HMAC_SECRET=
GLUECRON_URL=https://gluecron.com

# Infrastructure tokens (optional — Vercel + Cloudflare for deploy hooks)
VERCEL_TOKEN=
CF_ZONE_ID=
CF_API_TOKEN=

# Admin API token (optional — machine-to-machine access)
ADMIN_TOKEN=

# Phase 5.3 — external integration token encryption (≥32 chars)
# Encrypts customer-supplied access tokens at rest. Rotating this value
# invalidates every stored token. Generate with: openssl rand -hex 32
INTEGRATIONS_SECRET=

# Phase 5.3.1 — Sentry OAuth (customer-side integration)
# Until both are set, /api/integrations/sentry/connect returns 503.
# Create OAuth app at sentry.io/settings/<org>/developer-settings.
SENTRY_CLIENT_ID=
SENTRY_CLIENT_SECRET=

# gatetest.ai's OWN Sentry — error capture for the website
# DSN from sentry.io project settings → Client Keys (DSN). Public-safe.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Optional commit SHA so errors are pinned to a release
NEXT_PUBLIC_SENTRY_RELEASE=
SENTRY_RELEASE=

# Self-heal webhook — Sentry issue alert → Claude diagnosis → GitHub issue in <60s
# Set in Sentry: Project Settings → Integrations → Webhooks → Client Secret
SENTRY_WEBHOOK_SECRET_HEAL=
