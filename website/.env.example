# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Public
NEXT_PUBLIC_BASE_URL=https://gatetest.ai
NEXT_PUBLIC_APP_VERSION=1.0.0

# Gluecron (primary git host)
GLUECRON_BASE_URL=https://gluecron.com
GLUECRON_API_TOKEN=glc_...
GLUECRON_API_URL=https://gluecron.com/api
GLUECRON_TOKEN=glc_...

# GitHub App (dual-host — GitHub Marketplace distribution)
GATETEST_APP_ID=
GATETEST_PRIVATE_KEY=
GATETEST_WEBHOOK_SECRET=
GATETEST_GITHUB_TOKEN=
GIT_HOST=github

# Social OAuth — customer login (GitHub + GitLab + Google)
# SESSION_SECRET is shared across all three providers (high-entropy random string)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
# Redirect URI: https://gatetest.ai/api/auth/gitlab/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI: https://gatetest.ai/api/auth/google/callback
SESSION_SECRET=

# Admin
GATETEST_ADMIN_PASSWORD=change_me_before_deploy
GATETEST_ADMIN_USERNAMES=
GATETEST_API_KEY=
# Vercel Cron auth — set to any random secret; Vercel sends it as "Authorization: Bearer <value>"
# Without this, /api/watches/tick and /api/scan/worker/tick are open to any caller in production
CRON_SECRET=

# AI
ANTHROPIC_API_KEY=

# Multi-Agent Consensus (Nuclear tier opt-in only) — second-agent cross-check
OPENAI_API_KEY=

# Database (Neon serverless Postgres)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Build metadata (set by CI — no value needed locally)
APP_VERSION=
GIT_COMMIT=

# SSH healing (optional — remote server access for auto-fix)
GATETEST_SSH_HOST=
GATETEST_SSH_PORT=22
GATETEST_SSH_USER=
GATETEST_SSH_PASSWORD=
GATETEST_SSH_KEY=

# Runtime / monitoring (optional — CLI and monitor daemon)
GATETEST_ADMIN_URL=https://gatetest.ai/admin
GATETEST_ALERT_WEBHOOK=
GATETEST_REPORTS_DIR=.gatetest/reports
GATETEST_PURGE_WEBHOOK=
GATETEST_DEPLOY_HOOK=
GATETEST_RESTART_HOOK=
GATETEST_FIX_MAX_ATTEMPTS=3
GATETEST_CALLBACK_SECRET=
GATETEST_HMAC_SECRET=
GLUECRON_URL=https://gluecron.com

# Infrastructure tokens (optional — Vercel + Cloudflare for deploy hooks)
VERCEL_TOKEN=
CF_ZONE_ID=
CF_API_TOKEN=

# Admin API token (optional — machine-to-machine access)
ADMIN_TOKEN=

# SEO auto-submission — IndexNow protocol (optional)
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# Visit https://gatetest.ai/<key>.txt to verify, then POST /api/admin/seo/submit
INDEXNOW_KEY=

# Marketing feature flags (optional — set to "1" to activate)
# NEXT_PUBLIC_LAUNCH_HN: shows a live HN launch-thread badge on marketing pages
# NEXT_PUBLIC_LIVE_COUNTER: shows a live scan counter (requires external feed)
NEXT_PUBLIC_LAUNCH_HN=
NEXT_PUBLIC_LIVE_COUNTER=

# Arena repo — owner/name of the gatetest-arena live demo. Used by
# /testing to render real-time inject-bug + AI-fix-PR activity. Default:
# crclabs-hq/gatetest-arena. Override only when running a fork.
ARENA_REPO=crclabs-hq/gatetest-arena

# ── Internal service auth (machine-to-machine) ──
# Shared secret for internal GateTest→GateTest API calls (/api/fixes).
GATETEST_INTERNAL_TOKEN=
# Bearer key the Slack bridge uses to call internal scan APIs.
GATETEST_INTERNAL_API_KEY=
# HMAC secret verifying inbound Sentry "self-heal" webhooks.
SENTRY_WEBHOOK_SECRET_HEAL=

# ── Sentry OAuth integration (install flow) ──
SENTRY_CLIENT_ID=
SENTRY_CLIENT_SECRET=

# ── Sentry error monitoring (SDK) ──
# Server + edge runtime DSN. NEXT_PUBLIC_* variants are exposed to the browser.
SENTRY_DSN=
SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_RELEASE=

# ── Scan engine toggles ──
# Set to "1" to force the lighter runTier path instead of the CLI engine.
GATETEST_DISABLE_CLI_ENGINE=
# Set to "1" to load auto-generated rule-based fixers at runtime.
GATETEST_LOAD_AUTO_RULES=
# Public base URL used to build absolute links in web-scan results.
GATETEST_PUBLIC_BASE_URL=https://gatetest.ai

# ── Gluecron callback (github-host scan jobs) ──
GLUECRON_CALLBACK_URL=
GLUECRON_CALLBACK_SECRET=

# ── Cross-platform dispatch (Vapron / Crontech runtime callbacks) ──
VAPRON_DISPATCH_SECRET=
CRONTECH_DISPATCH_SECRET=

# ── Slack notifications ──
# Signing secret for verifying inbound Slack slash-command requests.
SLACK_SIGNING_SECRET=
# Incoming-webhook URL for posting scan-complete messages.
SLACK_WEBHOOK_URL=

# ── AI budget / cost guardrails (all optional — sane defaults in code) ──
GATETEST_INPUT_USD_PER_MTOK=
GATETEST_OUTPUT_USD_PER_MTOK=
GATETEST_MAX_TOKENS_PER_SCAN=
GATETEST_MAX_USD_PER_SCAN=
GATETEST_MAX_USD_QUICK=
GATETEST_MAX_USD_FULL=
GATETEST_MAX_USD_SCAN_FIX=
GATETEST_MAX_USD_NUCLEAR=
GATETEST_MAX_TOKENS_QUICK=
GATETEST_MAX_TOKENS_FULL=
GATETEST_MAX_TOKENS_SCAN_FIX=
GATETEST_MAX_TOKENS_NUCLEAR=
# Monthly USD budget cap for the continuous-scan subscription worker.
CONTINUOUS_AI_BUDGET_USD=

# ── Transactional email (Resend — digest mailer) ──
RESEND_API_KEY=
RESEND_FROM=

# ── External integrations store ──
# HMAC secret for verifying inbound third-party integration payloads.
INTEGRATIONS_SECRET=

# ── Visual-regression baseline capture (capture-baseline.mjs, dev tooling) ──
# Target URL to snapshot and directory to write baselines into.
TARGET_URL=http://localhost:3000
BASELINE_DIR=.baselines
