# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Public
NEXT_PUBLIC_BASE_URL=https://gatetest.ai

# Gluecron (our git host — replaces GitHub App integration)
GLUECRON_BASE_URL=https://gluecron.com
GLUECRON_API_TOKEN=glc_

# GitHub OAuth (admin panel + customer login — NOT the App, kept intentionally)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=
SESSION_SECRET=
GATETEST_ADMIN_USERNAMES=

# AI
ANTHROPIC_API_KEY=

# Database (Neon serverless Postgres)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Admin panel password — gates /admin (which can bypass Stripe for support).
# Generate with: openssl rand -base64 32
GATETEST_ADMIN_PASSWORD=

# SSH Auto-Heal Agent credentials (consumed by /api/heal/ssh).
# All optional; the agent also accepts these on the POST body.
# Use either GATETEST_SSH_PASSWORD or GATETEST_SSH_KEY, not both.
GATETEST_SSH_HOST=
GATETEST_SSH_PORT=22
GATETEST_SSH_USER=
GATETEST_SSH_PASSWORD=
GATETEST_SSH_KEY=

# Build metadata surfaced by /api/platform-status (optional; populated by CI).
# Vercel exposes VERCEL_GIT_COMMIT_SHA — wire it via the build env if you want
# it surfaced under GIT_COMMIT.
APP_VERSION=dev
GIT_COMMIT=unknown

# Signal Bus / cron — also lives in the repo-root .env.example. Both deployments
# need the same value or the inbound /api/events/push signature check fails.
GLUECRON_EMITTER_SECRET=
CRON_SECRET=
