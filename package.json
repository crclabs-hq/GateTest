{
  "name": "gatetest",
  "version": "1.41.0",
  "description": "67 modules. One gate. One decision. AI-native QA — kills SonarQube, Snyk, and every fragmented quality tool. Ships an MCP server so Claude Code, Cursor, Cline, Windsurf, and Continue can invoke it natively. Zero dependencies.",
  "main": "src/index.js",
  "bin": {
    "gatetest": "./bin/gatetest.js",
    "gatetest-mcp": "./bin/gatetest-mcp.js"
  },
  "files": [
    "bin/",
    "src/",
    "docs/MCP.md",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --test tests/**/*.test.js",
    "app": "node src/app-server.js",
    "gatetest": "node bin/gatetest.js",
    "gatetest:mcp": "node bin/gatetest-mcp.js",
    "gatetest:full": "node bin/gatetest.js --suite full",
    "gatetest:quick": "node bin/gatetest.js --suite quick",
    "gatetest:security": "node bin/gatetest.js --module security",
    "gatetest:visual": "node bin/gatetest.js --module visual",
    "gatetest:a11y": "node bin/gatetest.js --module accessibility",
    "gatetest:perf": "node bin/gatetest.js --module performance",
    "gatetest:seo": "node bin/gatetest.js --module seo",
    "gatetest:links": "node bin/gatetest.js --module links",
    "gatetest:scan": "node bin/gatetest.js --mode scan",
    "gatetest:report": "node bin/gatetest.js --report",
    "lint": "eslint src/ --ext .js",
    "precommit": "node src/hooks/pre-commit.js",
    "prepush": "node src/hooks/pre-push.js"
  },
  "keywords": [
    "testing",
    "qa",
    "quality-assurance",
    "gatetest",
    "gatecode",
    "claude",
    "ci-cd",
    "security",
    "accessibility",
    "performance",
    "visual-regression",
    "seo",
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "ai-tools",
    "claude-code",
    "cursor",
    "cline",
    "windsurf",
    "continue",
    "agent",
    "sonarqube-alternative",
    "snyk-alternative",
    "static-analysis",
    "linter",
    "sast",
    "owasp",
    "redos",
    "ssrf",
    "n-plus-one",
    "import-cycle",
    "feature-flags",
    "secret-detection"
  ],
  "homepage": "https://gatetest.ai",
  "bugs": {
    "url": "https://github.com/ccantynz-alt/gatetest/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ccantynz-alt/gatetest.git"
  },
  "author": "GateTest Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {},
  "devDependencies": {}
}
