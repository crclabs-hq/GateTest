{
  "modules": {
    "envVars": {
      "skipRuntimeCheck": true,
      "reason": "This repo self-scans in GitHub Actions. The website/.env.example keys are for Vercel deployment, not the CI environment â€” the runtime completeness check flags Stripe/Anthropic/Database keys as missing since they are not CI secrets."
    },
    "prSize": {
      "maxFilesChangedWarning": 80,
      "maxFilesChangedError": 200,
      "maxLinesChangedWarning": 3000,
      "maxLinesChangedError": 10000,
      "maxLinesPerFileWarning": 800,
      "maxLinesPerFileError": 2000,
      "reason": "GateTest is in active development â€” large feature PRs adding new modules, tests, and docs are expected and intentional. prSize still catches runaway diffs but at a scale appropriate for this codebase."
    },
    "codeQuality": {
      "excludePaths": [
        "bin/",
        "tests/",
        "scripts/",
        "setup.js",
        "src/reporters/",
        "src/hooks/",
        "src/scanners/",
        "src/ai-loop.js",
        "src/app-server.js",
        "src/core/github-bridge.js",
        "website/app/legal/",
        "website/app/docs/",
        "website/app/admin/AdminPanel.tsx",
        "website/app/admin/health/",
        "website/app/api/",
        "website/app/dashboard/",
        "website/app/scan/"
      ]
    }
  },
  "thresholds": {
    "maxFileLength": 800,
    "maxFunctionLength": 400
  },
  "triggers": {
    "pullRequest": {
      "enabled": true,
      "branchPatterns": [
        "main",
        "master",
        "claude/*",
        "claude/**",
        "gatetest/*",
        "gatetest/**"
      ],
      "reason": "Every PR opened from agent branch prefixes (claude/*, gatetest/*) must be auto-scanned. GateTest dogfoods itself â€” the scanner repo eats its own food."
    },
    "push": {
      "enabled": true,
      "branchPatterns": ["main", "master"]
    },
    "schedule": [
      {
        "name": "empire-smoke",
        "cron": "*/5 * * * *",
        "command": "node integrations/smoke/empire-smoke.ts",
        "reason": "Runs the cross-repo smoke harness every 5 minutes against the Crontech / Gluecron / GateTest deployments. Owned by agent 6 â€” allowMissing is true until the harness file lands.",
        "severity": "error",
        "timeoutSeconds": 180,
        "allowMissing": true
      }
    ]
  },
  "rules": {
    "schemaRegressionGate": {
      "enabled": true,
      "severity": "error",
      "when": {
        "pathsChanged": [
          "src/**/*.ts",
          "src/**/*.js",
          "src/scanners/**",
          "src/reporters/**",
          "**/schema.ts",
          "**/*.types.ts",
          "**/types/**/*.ts"
        ]
      },
      "command": "npm run typecheck --if-present",
      "scope": "dependents",
      "reason": "When exported scanner / reporter types move, re-typecheck every dependent module so integrators don't break silently."
    },
    "secretLeak": {
      "enabled": true,
      "severity": "error",
      "scanEveryPR": true,
      "patterns": [
        "\\.env(\\..+)?$",
        "\\.env\\.local$",
        "\\.env\\.production$",
        ".*\\.pem$",
        ".*\\.key$",
        "(^|/)id_rsa$",
        "(^|/)id_ed25519$",
        "(^|/)\\.pgpass$",
        "(^|/)credentials\\.json$",
        "(^|/)service-account.*\\.json$"
      ],
      "contentPatterns": [
        "AKIA[0-9A-Z]{16}",
        "ghp_[A-Za-z0-9]{36,}",
        "gho_[A-Za-z0-9]{36,}",
        "github_pat_[A-Za-z0-9_]{80,}",
        "sk-ant-[A-Za-z0-9_-]{40,}",
        "sk-[A-Za-z0-9]{40,}",
        "xox[baprs]-[A-Za-z0-9-]{10,}",
        "-----BEGIN (RSA |OPENSSH |EC |DSA |PGP )?PRIVATE KEY-----"
      ],
      "reason": "Verify .env / *.pem / id_rsa / hardcoded tokens don't slip through."
    }
  }
}
