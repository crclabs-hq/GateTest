# ============================================================================
# GateTest — environment variables
# ============================================================================
#
# Website-specific env vars also live in website/.env.example. This file
# captures repo-level integration secrets.
#

# ---- Gluecron async scan-result callback ----------------------------------
# When a Gluecron-originated scan completes (POST body carries
# `source: "gluecron"`), GateTest POSTs the result back to Gluecron here.
# Wire contract: Gluecron.com/GATETEST_HOOK.md
#
# Default callback URL: https://gluecron.com/api/hooks/gatetest
GLUECRON_CALLBACK_URL=

# Shared bearer token Gluecron presents on the receiver side
# (`Authorization: Bearer ${GLUECRON_CALLBACK_SECRET}`). Generate with:
#   openssl rand -hex 32
GLUECRON_CALLBACK_SECRET=

# ---- Signal Bus E1 — inbound push events + cron worker ---------------------
# HMAC secret for the inbound /api/events/push endpoint. Gluecron signs every
# POST body with HMAC-SHA256 keyed on this value and sends the result in the
# X-Signal-Signature header (format: `sha256=<hex>`). The secret MUST match
# the one Gluecron is configured with — rotate both sides together.
# Generate with: openssl rand -hex 32
GLUECRON_EMITTER_SECRET=

# Vercel cron validation header. The cron entry in vercel.json for
# /api/scan/worker/tick forwards this value; we also re-use it for the
# fire-and-forget inline kick from /api/events/push. REQUIRED in
# production — the worker fails closed (rejects every request) when
# this is unset, so ticks stop firing until it's set.
CRON_SECRET=

# ---- Outbound: calling Gluecron ------------------------------------------
# GateTest calls Gluecron for repo meta, trees, blobs, statuses, PR
# comments, branch creation, file upserts, and PR opening. See
# src/core/gluecron-bridge.js and website/app/lib/gluecron-client.ts for
# the full wire surface.
#
# Base URL of the Gluecron deployment. Defaults to https://gluecron.com.
GLUECRON_BASE_URL=https://gluecron.com

# PAT (scope: repo). Format: glc_<64hex>. Generate at
# https://gluecron.com/settings/tokens — the token authenticates every
# outbound call we make to Gluecron.
GLUECRON_API_TOKEN=glc_

# ─────────────────────────────────────────────────────────────────────────────
# GitHub
# ─────────────────────────────────────────────────────────────────────────────
# Personal access token (PAT) fallback when the GitHub App isn't installed
# on a target repo. Used by website/app/lib/gluecron-client.ts.
GH_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Vapron (worker tier — headless-browser runtime scans; formerly Crontech)
# ─────────────────────────────────────────────────────────────────────────────
# GateTest → Vapron dispatch (website/app/lib/vapron-dispatch.js). All three
# must be set or /api/web/scan silently skips the runtime layer and reports
# "runtime checks unavailable" alongside the static-probe results.
# Vapron-side endpoint: POST {VAPRON_BASE_URL}/api/jobs/web-runtime-scan
VAPRON_BASE_URL=
VAPRON_API_TOKEN=
# HMAC secret shared with the worker tier for inbound/outbound webhook signing.
# VAPRON_* names are canonical; CRONTECH_* are the legacy aliases read as a
# fallback. Set at least one. Generate with: openssl rand -hex 32
VAPRON_DISPATCH_SECRET=
CRONTECH_DISPATCH_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Sentry (error monitoring)
# ─────────────────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_RELEASE=
SENTRY_CLIENT_ID=
SENTRY_CLIENT_SECRET=
SENTRY_WEBHOOK_SECRET_HEAL=

# ─────────────────────────────────────────────────────────────────────────────
# Misc integrations + admin
# ─────────────────────────────────────────────────────────────────────────────
# Bearer token for the /api/integrations admin endpoints.
INTEGRATIONS_SECRET=

# Internal-tier API key (admin/sibling-product). Set to bypass tier/billing.
GATETEST_INTERNAL_TOKEN=

# Public base URL the website advertises (for callback URLs, OG, etc.).
GATETEST_PUBLIC_BASE_URL=https://gatetest.ai

# ─────────────────────────────────────────────────────────────────────────────
# Engine-runtime toggles (rarely set — see src/index.js / scan-modules/types.ts)
# ─────────────────────────────────────────────────────────────────────────────
# Set to "1" to force the website to use the in-process runTier engine
# instead of the CLI engine for repo scans. Diagnostic only.
GATETEST_DISABLE_CLI_ENGINE=

# Live URL the chaos / runtime module probes when run via the GitHub Action
# with `chaos: true`. The Action sets this from its `chaos-url` input; you
# only set it manually if you're invoking `gatetest --module chaos` locally.
GATETEST_CHAOS_URL=

# Anthropic pricing for per-scan budget tracking (defaults baked in if unset).
GATETEST_INPUT_USD_PER_MTOK=3
GATETEST_OUTPUT_USD_PER_MTOK=15

# Per-scan hard caps — budget-tracker.js enforces these.
GATETEST_MAX_TOKENS_PER_SCAN=200000
GATETEST_MAX_USD_PER_SCAN=12

# Tracking-issue creator caps (scripts/track-non-fixable.js). When the
# action input `track-non-fixable: true` is set, an Issue is opened per
# error-severity finding the auto-fixer can't patch. This cap keeps
# first-time runs on noisy repos from spamming the customer's issue
# tracker. Default 20.
GATETEST_MAX_ISSUES=20

# Per-tier Anthropic budget caps — budget-tracker enforces these per scan.
# Override defaults baked into website/app/lib/budget-tracker.js.
GATETEST_MAX_USD_QUICK=
GATETEST_MAX_USD_FULL=
GATETEST_MAX_USD_SCAN_FIX=
GATETEST_MAX_USD_NUCLEAR=
GATETEST_MAX_TOKENS_QUICK=
GATETEST_MAX_TOKENS_FULL=
GATETEST_MAX_TOKENS_SCAN_FIX=
GATETEST_MAX_TOKENS_NUCLEAR=

# Sandbox runner config (recipe-promoter / regression-test-generator).
GATETEST_SANDBOX_WORKER=
GATETEST_SANDBOX_TASK=

# Flywheel: when "1", auto-rules from corpus/auto-rules/ are loaded into
# the deterministic detection layer at scan time. Leave unset for opt-in.
GATETEST_LOAD_AUTO_RULES=

# AI guardrails endpoint — optional HTTPS POST target that receives every
# Claude prompt + response for an external safety review pass. Leave unset
# to skip the guardrails hop. Used by src/modules/ai-guardrails.js.
GATETEST_AI_GUARDRAILS_ENDPOINT=

# Continuous tier — monthly Claude AI-review allowance per $49/mo
# subscription, in USD. Deterministic scans are never metered; this caps
# only AI-review spend per subscription per calendar month. Default: 10.
# Used by website/app/lib/continuous-subscription-store.js.
CONTINUOUS_AI_BUDGET_USD=

# ─────────────────────────────────────────────────────────────────────────────
# Model selection (engine-models.js twins — src/core + website/app/lib)
# ─────────────────────────────────────────────────────────────────────────────
# Force a specific fix model everywhere (sonnet | opus | fable, or a full
# model id). Wins over per-tier defaults; explicit user choice wins over it.
GATETEST_FIX_MODEL=

# Override the cheap/high-volume model (default: claude-sonnet-5).
GATETEST_CHEAP_MODEL=

# Override the refusal-fallback model (default: claude-opus-4-8).
GATETEST_FALLBACK_MODEL=

# Fable 5 pricing overrides for budget-tracker.js (USD per MTok).
GATETEST_FABLE_INPUT_USD_PER_MTOK=
GATETEST_FABLE_OUTPUT_USD_PER_MTOK=

# ─────────────────────────────────────────────────────────────────────────────
# MCP server (bin/gatetest-mcp.mjs + packages/mcp-remote)
# ─────────────────────────────────────────────────────────────────────────────
# Base URL the local MCP server calls for hosted-API tools (default:
# https://gatetest.ai).
GATETEST_API_BASE_URL=

# Set to "0" to disable remote-MCP telemetry counters (packages/mcp-remote).
GATETEST_MCP_TELEMETRY=

# ─────────────────────────────────────────────────────────────────────────────
# Scan-findings flywheel telemetry (src/core/scan-telemetry.js + uploader)
# ─────────────────────────────────────────────────────────────────────────────
# Set to "1" to fully opt out of anonymized module+count telemetry.
# (.gatetest.json {"telemetry": false} does the same per-repo.)
GATETEST_NO_TELEMETRY=

# Override the telemetry upload endpoint (default:
# https://gatetest.ai/api/telemetry/scan). Points at a staging box in dev.
GATETEST_TELEMETRY_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Live-URL module targets — set only when running a single browser module
# locally against a specific URL (the CLI --url flag is the normal path).
# ─────────────────────────────────────────────────────────────────────────────
GATETEST_API_HEALTH_URL=
GATETEST_CONSOLE_ERRORS_URL=
GATETEST_CROSS_BROWSER_URL=
GATETEST_DESIGN_COMPLIANCE_URL=
GATETEST_FORM_TESTING_URL=
GATETEST_INTERACTIVE_URL=
GATETEST_MOBILE_URL=
GATETEST_PERF_BUDGET_URL=
GATETEST_VISUAL_URL=

# Visual-baseline capture script (scripts/capture-visual-baseline.mjs).
TARGET_URL=
BASELINE_DIR=

# ─────────────────────────────────────────────────────────────────────────────
# Slack (visual-regression alerts + /gatetest slash command)
# ─────────────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_CHANNEL=
# Signing secret for inbound /api/slack/events (fail-closed verification).
SLACK_SIGNING_SECRET=
# Internal API key the Slack route uses to call the scan API on behalf of
# a workspace.
GATETEST_INTERNAL_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Misc engine/website toggles
# ─────────────────────────────────────────────────────────────────────────────
# Set to "1" to silence the free-tier upsell footer in CLI output.
GATETEST_NO_UPSELL=

# Bearer token that unlocks the verbose env-var diagnostic on /api/status.
GATETEST_STATUS_TOKEN=

# From-address for digest emails (website/app/lib/digest-mailer.js).
# Must be a sender your Resend account has verified.
RESEND_FROM=
