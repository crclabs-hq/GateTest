{
  "id": "ship-cookie-httponly-1",
  "ruleKey": "cookie-security:js-httponly-false",
  "module": "cookieSecurity",
  "pattern": "httpOnly\\s*:\\s*false",
  "transform": {
    "kind": "regex-replace",
    "find": "httpOnly(\\s*):(\\s*)false",
    "replace": "httpOnly$1:$2true",
    "flags": "g"
  },
  "promotedAt": "2026-05-17T00:00:00Z",
  "promotedFromCustomers": 6,
  "winRate": 0.96,
  "description": "Flip httpOnly: false to true on cookie/session options. Prevents document.cookie XSS exfiltration. Mirrors ast-httponly.",
  "schemaVersion": 1
}
