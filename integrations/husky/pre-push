#!/usr/bin/env bash
# ============================================================================
# GATETEST PRE-PUSH HOOK — PROTECTED INTEGRATION FILE
# ============================================================================
# Philosophy (Craig 2026-05-29):
#   "GateTest needs to be software that is the fixer, not the blocker.
#    It needs to be the world's biggest painkiller. It needs to fix
#    everything."
#
# Two modes, NEITHER blocks the push:
#
#   ADMIN  — our own projects (Crontech, Gluecron, GateTest itself, any
#            repo whose `.gatetest.json` has `"owner": "crclabs-hq"` or
#            `"admin": true`, or any env with GATETEST_ADMIN=1).
#            Behaviour: silent pass. We trust the operator; CI is the
#            actual quality gate.
#
#   CUSTOMER — every other repo. Behaviour: advisory output (findings
#              are surfaced for awareness) but push always proceeds.
#              CI runs the strict gate and (on paid Scan + Fix tiers)
#              auto-opens a fix PR. To fix locally before pushing,
#              run: gatetest --fix
#
# MUST NOT be removed without Craig's authorisation. The CI gate workflow
# (integrations/github-actions/gatetest-gate.yml) is the actual enforcement
# layer — see CLAUDE.md → PROTECTED PLATFORMS.
#
# Install location in target repo: .husky/pre-push (chmod +x)
# Source of truth: https://github.com/crclabs-hq/gatetest
#                  /integrations/husky/pre-push
#
# SPEED CONTRACT: under 30 seconds on a typical repo. Pushes are real-time
# UX; a slow hook is hostile to flow.
# ============================================================================
set -e

GATETEST_CACHE="${GATETEST_CACHE:-$HOME/.cache/gatetest}"

# ---------------------------------------------------------------------------
# Skip in CI — the same gate runs server-side via the gatetest-gate.yml
# workflow. Running it twice is pure latency tax on the push.
# ---------------------------------------------------------------------------
if [ -n "${CI:-}" ] || [ -n "${GITHUB_ACTIONS:-}" ] || [ -n "${GITLAB_CI:-}" ]; then
  echo "[GateTest] CI environment detected — gate runs in CI workflow, skipping local pre-push."
  exit 0
fi

# ---------------------------------------------------------------------------
# Opt-out env var — set GATETEST_SKIP=1 to skip even the advisory pass.
# ---------------------------------------------------------------------------
if [ "${GATETEST_SKIP:-}" = "1" ]; then
  echo "[GateTest] GATETEST_SKIP=1 — skipping advisory gate."
  exit 0
fi

# ---------------------------------------------------------------------------
# Admin detection — silent pass for admin-owned repos.
# Three signals (any one is sufficient):
#   1. Env var GATETEST_ADMIN=1
#   2. .gatetest.json contains "admin": true
#   3. .gatetest.json contains "owner": "crclabs-hq"
# ---------------------------------------------------------------------------
IS_ADMIN=0
if [ "${GATETEST_ADMIN:-}" = "1" ]; then
  IS_ADMIN=1
elif [ -f ".gatetest.json" ]; then
  if grep -Eq '"admin"[[:space:]]*:[[:space:]]*true' .gatetest.json 2>/dev/null; then
    IS_ADMIN=1
  elif grep -Eq '"owner"[[:space:]]*:[[:space:]]*"crclabs-hq"' .gatetest.json 2>/dev/null; then
    IS_ADMIN=1
  fi
fi

if [ "$IS_ADMIN" = "1" ]; then
  echo "[GateTest] Admin repo — silent pass. CI gate is the source of truth."
  exit 0
fi

# ---------------------------------------------------------------------------
# Cache management — first run clones the gatetest repo into $GATETEST_CACHE,
# subsequent runs reuse it. Cold clone is async-best-effort: we never block
# a first push waiting for the clone.
# ---------------------------------------------------------------------------
if [ ! -d "$GATETEST_CACHE/.git" ]; then
  echo "[GateTest] First-time setup — fetching GateTest into $GATETEST_CACHE."
  echo "[GateTest] (This first push will skip the advisory gate; subsequent pushes will run it.)"
  mkdir -p "$(dirname "$GATETEST_CACHE")"
  git clone --depth 1 https://github.com/crclabs-hq/gatetest.git "$GATETEST_CACHE" 2>/dev/null || true
  if [ ! -d "$GATETEST_CACHE/.git" ]; then
    echo "[GateTest] Clone unavailable — letting push through; CI gate is the source of truth."
    exit 0
  fi
  exit 0
fi

# Best-effort cache refresh — capped at 5s, never blocks the push.
( cd "$GATETEST_CACHE" && timeout 5 git pull --ff-only --depth 1 origin HEAD >/dev/null 2>&1 || true )

# ---------------------------------------------------------------------------
# Customer mode: advisory output. We capture the exit code but DO NOT
# propagate it — this hook never blocks. The strict gate lives in CI;
# paid Scan + Fix tiers auto-open a fix PR.
# ---------------------------------------------------------------------------
echo "[GateTest] Running advisory gate (20s cap, never blocks) ..."
GATETEST_FAST=1 timeout 20 \
  node "$GATETEST_CACHE/bin/gatetest.js" --suite quick --diff --project "$(pwd)" || gate_status=$?
gate_status="${gate_status:-0}"

if [ "$gate_status" = "0" ]; then
  echo "[GateTest] PASSED — pushing."
elif [ "$gate_status" = "124" ]; then
  echo "[GateTest] Advisory gate exceeded 20s cap — letting push through; CI gate will run."
else
  echo ""
  echo "[GateTest] Advisory: gate reported findings above."
  echo "[GateTest] Push proceeding — CI will run the strict gate and (on Scan + Fix tiers) auto-open a fix PR."
  echo "[GateTest] To fix locally before pushing again, run:  gatetest --fix"
fi

# The hook ALWAYS exits 0. The CI gate is the enforcement layer.
exit 0
